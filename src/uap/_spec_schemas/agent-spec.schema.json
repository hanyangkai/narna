{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uap.dev/schemas/v0.1/agent-spec.schema.json",
  "title": "UAP AgentSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "uap.dev/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Agent"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "creator", "createdAt"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable agent id (ULID/UUID)."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([+-][0-9A-Za-z.-]+)?$"
        },
        "creator": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "permissions", "policy"],
      "properties": {
        "capability": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "permissions": {
          "type": "array",
          "items": { "$ref": "#/$defs/permissionGrant" }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string" }
            }
          }
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": { "type": "string" },
            "preference": { "type": "string" },
            "params": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "adapter": { "type": "string" },
            "config": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ref"],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1,
              "description": "Policy pack reference, e.g. policies/trading-default@1.0.0"
            }
          }
        },
        "passport": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ref": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "permissionGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mode"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        },
        "mode": {
          "type": "string",
          "enum": ["allow", "deny", "ask"]
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "scope": {
          "type": "string"
        }
      }
    }
  }
}
