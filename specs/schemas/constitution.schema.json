{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narna.ai/schemas/v0.1/constitution.schema.json",
  "title": "NARNA Constitution",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "narna.ai/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Constitution"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "entityKind", "entityId", "owner", "createdAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "entityKind": {
          "type": "string",
          "enum": [
            "Agent",
            "Tool",
            "McpServer",
            "Workflow",
            "Prompt",
            "Dataset",
            "Plugin",
            "Memory",
            "ModelBinding"
          ]
        },
        "entityId": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "origin": { "type": "string" },
        "license": { "type": "string" },
        "createdAt": { "type": "string", "minLength": 1 },
        "signature": { "type": ["string", "null"] },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "capability", "permission", "policy", "evidence", "trust"],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "owner", "version"],
          "properties": {
            "id": { "type": "string" },
            "owner": { "type": "string" },
            "version": { "type": "string" },
            "signature": { "type": ["string", "null"] },
            "origin": { "type": "string" },
            "license": { "type": "string" },
            "policyRef": { "type": "string" },
            "trustProfile": { "type": "string" }
          }
        },
        "capability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supports"],
          "properties": {
            "supports": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "declares": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "level": { "type": "string" }
                }
              }
            }
          }
        },
        "permission": {
          "type": "object",
          "additionalProperties": false,
          "required": ["grants"],
          "properties": {
            "grants": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "mode"],
                "properties": {
                  "name": { "type": "string" },
                  "mode": {
                    "type": "string",
                    "enum": ["allow", "deny", "read", "write", "ask"]
                  },
                  "paths": { "type": "array", "items": { "type": "string" } },
                  "hosts": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rules"],
          "properties": {
            "ref": { "type": "string" },
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "effect"],
                "properties": {
                  "id": { "type": "string" },
                  "effect": {
                    "type": "string",
                    "enum": ["allow", "deny", "ask", "require"]
                  },
                  "action": { "type": "string" },
                  "when": { "type": "string" },
                  "evidence": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "humanReview": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requiredFor": {
              "type": "array",
              "items": { "type": "string" }
            },
            "timeoutSeconds": { "type": "integer", "minimum": 0 },
            "onTimeout": {
              "type": "string",
              "enum": ["deny", "allow", "ask"]
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mustProve"],
          "properties": {
            "mustLog": {
              "type": "array",
              "items": { "type": "string" }
            },
            "mustProve": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "retentionDays": { "type": "integer", "minimum": 1 },
            "hashAlg": { "type": "string" }
          }
        },
        "trust": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "minScore"],
          "properties": {
            "algorithm": { "type": "string" },
            "minScore": { "type": "number", "minimum": 0, "maximum": 1 },
            "inputs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "governance": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "orgId": { "type": "string" },
            "fleetId": { "type": "string" },
            "roles": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "supports": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "provider": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}
