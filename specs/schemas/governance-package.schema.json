{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narna.ai/schemas/v0.1/governance-package.schema.json",
  "title": "NARNA Governance Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "narna.ai/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "GovernancePackage"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "provider", "packageKind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "packageKind": {
          "type": "string",
          "enum": [
            "Constitution",
            "Compliance",
            "OrgPolicy",
            "RiskProfile",
            "HumanApproval"
          ]
        },
        "license": { "type": "string" },
        "disclaimer": { "type": "string" },
        "createdAt": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "effect"],
            "properties": {
              "id": { "type": "string" },
              "effect": {
                "type": "string",
                "enum": ["allow", "deny", "ask", "require"]
              },
              "action": { "type": "string" },
              "when": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "permissions": {},
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "humanReview": {
          "type": "object",
          "additionalProperties": true
        },
        "riskLevel": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constitution": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
