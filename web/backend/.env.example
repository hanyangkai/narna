UAP_DATABASE_URL=postgresql+psycopg2://uap:uap@localhost:5432/uap_cloud
UAP_REDIS_URL=redis://localhost:6379/0

# mock | paddle | stripe
UAP_BILLING_MODE=paddle
UAP_RATE_LIMIT_PER_MIN=120
UAP_CLOUD_CORS_ORIGIN=*
UAP_LOG_LEVEL=INFO

# Public site (used for Paddle success URLs when PADDLE_*_URL unset)
NARNA_PUBLIC_URL=https://narna.org

# ── Paddle Billing (live) ──
# https://vendors.paddle.com — onboarding must be Approved
PADDLE_API_KEY=
PADDLE_API_BASE=https://api.paddle.com
PADDLE_PRODUCT_ID=
PADDLE_SUCCESS_URL=https://narna.org/billing?paid=1
PADDLE_PACKAGE_SUCCESS_URL=https://narna.org/packages?paid=1
PADDLE_WEBHOOK_SECRET=

# Frontend build: VITE_PADDLE_CLIENT_TOKEN=live_… (Developer Tools → Authentication)

# ── Stripe (fallback) ──
STRIPE_API_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_SUCCESS_URL=https://narna.org/billing?paid=1
STRIPE_CANCEL_URL=https://narna.org/pricing
STRIPE_PACKAGE_SUCCESS_URL=https://narna.org/packages?paid=1
STRIPE_PACKAGE_CANCEL_URL=https://narna.org/packages?canceled=1
STRIPE_WEBHOOK_SECRET=

# Crypto
UAP_CRYPTO_MODE=mock
UAP_CRYPTO_RECEIVER_WALLET=
UAP_CRYPTO_BOT_ENABLED=0

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
