UAP_DATABASE_URL=postgresql+psycopg2://uap:uap@localhost:5432/uap_cloud

UAP_REDIS_URL=redis://localhost:6379/0

UAP_BILLING_MODE=mock

UAP_RATE_LIMIT_PER_MIN=120

UAP_CLOUD_CORS_ORIGIN=*

UAP_LOG_LEVEL=INFO



# Optional Sentry

SENTRY_DSN=

SENTRY_ENVIRONMENT=production

SENTRY_TRACES_SAMPLE_RATE=0.1



# Stripe mode only (UAP_BILLING_MODE=stripe)

STRIPE_API_KEY=

STRIPE_PRICE_ID_PRO=

STRIPE_PRICE_ID_TEAM=

STRIPE_PRICE_ID_BUSINESS=

STRIPE_SUCCESS_URL=http://localhost:5173/console

STRIPE_CANCEL_URL=http://localhost:5173/pricing

STRIPE_WEBHOOK_SECRET=



# Crypto billing (multi-chain)

UAP_CRYPTO_MODE=mock

UAP_CRYPTO_RECEIVER_WALLET=0x24DAb37fd89222710ce1D5A4c4E81e26D51E34D5

UAP_CRYPTO_BOT_ENABLED=1

UAP_CRYPTO_BOT_INTERVAL_SEC=20

UAP_CRYPTO_SCAN_BLOCKS=6000

UAP_CRYPTO_MIN_CONFIRMATIONS=3
UAP_CRYPTO_INVOICE_TTL_MIN=60
# Set 1 to keep pending invoices in mock mode (test QR/expiry UI)
UAP_CRYPTO_MOCK_PENDING=0



# Per-chain RPC URLs (required when UAP_CRYPTO_MODE=live)

# Free tiers: Alchemy, Infura, QuickNode, public RPC endpoints

UAP_ETH_RPC_URL=

UAP_POLYGON_RPC_URL=

UAP_BASE_RPC_URL=

UAP_ARBITRUM_RPC_URL=

UAP_BSC_RPC_URL=

