# Production env template for Coolify / VPS deploy
# Copy to Coolify environment variables

UAP_DATABASE_URL=postgresql+psycopg2://uap:CHANGE_ME@postgres:5432/uap_cloud
UAP_REDIS_URL=redis://redis:6379/0
UAP_BILLING_MODE=stripe
UAP_CRYPTO_MODE=live
UAP_CRYPTO_RECEIVER_WALLET=0x24DAb37fd89222710ce1D5A4c4E81e26D51E34D5
UAP_CRYPTO_BOT_ENABLED=1
UAP_CRYPTO_BOT_INTERVAL_SEC=20
UAP_CRYPTO_SCAN_BLOCKS=6000
UAP_CRYPTO_MIN_CONFIRMATIONS=3
UAP_RATE_LIMIT_PER_MIN=120
NARNA_PUBLIC_URL=https://registry.narna.dev
NARNA_REGISTRY_URL=https://api.registry.narna.dev
UAP_CLOUD_CORS_ORIGIN=https://registry.narna.dev
UAP_LOG_LEVEL=INFO

# Stripe
STRIPE_API_KEY=sk_live_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
STRIPE_SUCCESS_URL=https://console.yourdomain.com/console
STRIPE_CANCEL_URL=https://console.yourdomain.com/pricing
STRIPE_WEBHOOK_SECRET=whsec_...

# Multi-chain RPC (Alchemy / Infura / QuickNode)
UAP_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/KEY
UAP_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/KEY
UAP_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/KEY
UAP_ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/KEY
UAP_BSC_RPC_URL=https://bsc-dataseed.binance.org

# Optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
