# Production env for VPS / Coolify — narna.org
# Copy to /opt/narna/web/deploy/selfhost/.env

UAP_DATABASE_URL=postgresql+psycopg2://uap:CHANGE_ME@postgres:5432/uap_cloud
UAP_REDIS_URL=redis://redis:6379/0
UAP_BILLING_MODE=paddle
UAP_CRYPTO_MODE=mock
UAP_RATE_LIMIT_PER_MIN=120
NARNA_PUBLIC_URL=https://narna.org
UAP_CLOUD_CORS_ORIGIN=https://narna.org
UAP_LOG_LEVEL=INFO

# Paddle (LIVE — separate from sandbox)
PADDLE_API_KEY=
PADDLE_API_BASE=https://api.paddle.com
PADDLE_PRODUCT_ID=
PADDLE_SUCCESS_URL=https://narna.org/billing?paid=1
PADDLE_PACKAGE_SUCCESS_URL=https://narna.org/packages?paid=1
PADDLE_WEBHOOK_SECRET=

# Webhook URL: https://api.narna.org/v1/billing/paddle/webhook
# Default payment link (Paddle Dashboard): https://narna.org/billing

# Frontend build args (docker-compose / CI)
# VITE_API_URL=https://api.narna.org
# VITE_PADDLE_CLIENT_TOKEN=live_...

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
